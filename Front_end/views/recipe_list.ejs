<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Recipe List</title>
        <link rel="stylesheet" href="/css/recipe.css">
    </head>
    <body>
        <%- include('partials/header') %>
        <section class="search-bar">
            <form action="/search" method="GET" role="search">
                    <input type="search" id="site-search" name="q" placeholder="Search Catalogue for Recipes..." required>
                    <button>Search</button>
            </form>
        </section>
        <div class="recipe-block">
            <h1>Recipe List</h1>
            <% recipes.forEach(recipe => { %>
                <div class="recipe">
                    <h2><%= recipe.name %></h2>
                    <div class="recipe-info">
                    <p><%= recipe.description %></p>
                    <p><%= recipe.estimatedTime %> | <%= recipe.servings %> servings |
                    <%= recipe.difficulty %></p>
                    <p>Tags: <%- 
                        (Array.isArray(recipe.tags) ? recipe.tags : (recipe.tags ? [recipe.tags] : []))
                        .map(tag => `<a class="recipe_tag" href="/searchByTag/${tag}">${tag}</a>`)
                        .join(' ') || 'None'
                        %>
                    </p>
                    <a href="/api/recipes/<%= recipe._id %>">View Details</a>
                </div>
                </div>
            <% }) %>
        </div>

        <%- include('partials/footer') %>

        <script>
            async function deleteRecipe(id) {
                if (confirm('Are you sure you want to delete this recipe?')) {
                    try {
                        const response = await fetch(`/delete-recipe/${id}`, { method: 'DELETE' });
                        if (response.ok) {
                            location.reload();
                        } else {
                            alert('Failed to delete recipe');
                        }
                    } catch (error) {
                        console.error('Error deleting recipe:', error);
                        alert('An error occurred while deleting the recipe');
                    }
                }
            }
        </script>
    </body>
</html>