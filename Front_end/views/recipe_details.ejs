<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= recipe.name %> - Recipe Details</title>
    <link rel="stylesheet" href="/css/recipe.css">
</head>
<body>
    <%- include('partials/header') %>
    <h1><%= recipe.name %></h1>
    <h3>Rating: 
        <% 
            const comments = recipe.comments || [];
            const ratings = comments.map(c => Number(c.rating)).filter(r => !isNaN(r));
        %>
        <%= (ratings.length > 0)
            ? ((ratings.reduce((a, b) => a + b, 0) / ratings.length).toFixed(1) + ' / 5')
            : "No ratings yet" %>
        <% if (ratings.length > 0) { %>
            <span style="font-size:0.8em; color:#666;">(<%= ratings.length %>)</span>
        <% } %>
    </h3>
    <p><%= recipe.description %></p>
    <% function formatTimestamp(ts) {
        const d = new Date(ts);
        const h24 = d.getHours();
        const hours = ((h24 % 12) || 12);
        const ampm = h24 >= 12 ? 'pm' : 'am';
        const minutes = String(d.getMinutes()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        const year = d.getFullYear();
        return `${hours}:${minutes}${ampm} ${month}-${day}-${year}`;
    } %>
    <p><%= recipe.estimatedTime %> | <%= recipe.servings %> servings | <%= recipe.difficulty %></p>
    <p>Tags: <%-
        (Array.isArray(recipe.tags) ? recipe.tags : (recipe.tags ? [recipe.tags] : []))
        .map(tag => `<a class="recipe_tag" href="/searchByTag/${tag}">${tag}</a>`)
        .join(', ') || 'None'
    %></p>
    <h2>Ingredients</h2>
    <ul>
        <% recipe.ingredients.forEach(ingredient => { %>
            <li><%= ingredient.item %>, <%= ingredient.amount %></li>
        <% }) %>
    </ul>
    <h2>Instructions</h2>
    <ol>
        <% recipe.directions.forEach(direction => { %>
            <li><%= direction %></li>
        <% }) %>
    </ol>
    <div>
        <% if (isAdmin) { %>
            <button onclick="deleteRecipe('<%= recipe._id %>')">Delete</button>
            <button onclick="editRecipe('<%= recipe._id %>')">Edit</button>
        <% } %>
    </div>
    <div id="Comments">
        <h2>Comments</h2>

        <% const alreadyCommented = userid && comments.some(c => c.userId === userid); %>

        <h3>Add a Comment</h3>
        <% if (!useremail) { %>
            <p>Please <a href="/login">login</a> to leave a comment</p>
        <% } else if (alreadyCommented) { %>
            <p>You have already commented on this recipe.</p>
        <% } else { %>
            <form action="/recipes/<%= recipe._id %>/comments" method="POST">
                <textarea name="comment" rows="4" cols="50" required></textarea><br>
                Rating: <input type="number" id="rating-input" name="rating" min="0" max="5" required> / 5<br>
                <button type="submit">Submit Comment</button>
            </form>
        <% } %>
            <% if (comments.length > 0) { %>
                <% comments.forEach((comment, index) => { %>
                    <div class="comment">
                        <div class="comment-user"><strong><%= comment.username %></strong></div>
                        <div class="comment-rating">Rating: <%= comment.rating %>/5</div>
                        <div class="comment-text"><%= comment.text %></div>
                        <div class="comment-time" style="font-size:0.9em; color:#555;">
                            <%= formatTimestamp(comment.timestamp) %>
                        </div>
                        <% if ((userid && comment.userId === userid) || isAdmin) { %>
                            <button onclick="deleteComment('<%= recipe._id %>', <%= index %>)">Delete</button>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No comments yet. Be the first to comment!</p>
            <% } %>
    </div>
    <%- include('partials/footer') %>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.getElementById('rating-input');
            if (input) {
                input.addEventListener('blur', () => {
                    let v = parseFloat(input.value);
                    if (isNaN(v)) {
                        input.value = 0;
                        return;
                    }
                    if (v < 0) input.value = 0;
                    else if (v > 5) input.value = 5;
                });
            }
        });

        async function deleteComment(recipeId, index) {
            if (confirm('Are you sure you want to delete this comment?')) {
                const res = await fetch(`/recipes/${recipeId}/comments/${index}`, {
                    method: 'DELETE'
                });
                if (res.ok) 
                    location.reload();
                else
                    alert('Failed to delete comment');
            }
        }

        async function deleteRecipe(id) {
            if (confirm('Are you sure you want to delete this recipe?')) {
                try {
                    const response = await fetch(`/delete-recipe/${id}`, { method: 'DELETE' });
                    if (response.ok) {
                        window.location.href = '/recipe_list';
                    } else {
                        alert('Failed to delete recipe');
                    }
                } catch (error) {
                    console.error('Error deleting recipe:', error);
                    alert('An error occurred while deleting the recipe');
                }
            }
        }

        async function editRecipe(id) {
            window.location.href = `/edit_recipe/${id}`;
        }
    </script>
</body>
</html>